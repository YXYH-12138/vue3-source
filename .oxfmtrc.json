{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	// 使用tab缩进
	"useTabs": true,
	// 指定每个缩进级别的空格数
	"tabWidth": 2,
	// 一行最多多少个字符
	"printWidth": 100,
	// 使用单引号
	"singleQuote": false,
	// 在语句末尾打印分号
	"semi": true,
	// 换行符使用 可选值"<auto|lf|crlf|cr>"
	"endOfLine": "crlf",
	// 没有尾随逗号
	"trailingComma": "none",
	"ignorePatterns": ["./node_modules"]
}
